# ─────────────────────────────────────────────────────────────────────────────
# CatoCode Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI (required) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_BASE_URL=https://api.anthropic.com/v1 # optional custom endpoint

# ── GitHub (required) ────────────────────────────────────────────────────────
# Create at: https://github.com/settings/tokens
# Required scopes: repo
GITHUB_TOKEN=ghp_...

# ── Git identity (for commits made inside the worker container) ──────────────
GIT_USER_NAME=CatoCode
GIT_USER_EMAIL=catocode@bot.local

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000                                      # Host port for the webhook server

# ── Tuning ───────────────────────────────────────────────────────────────────
MAX_CONCURRENT=3                               # Max concurrent activities
CATOCODE_PATROL_MAX_ISSUES=5                   # Max issues to create per patrol window
CATOCODE_PATROL_WINDOW_HOURS=12                # Rolling window for patrol
CATOCODE_MEM=8g                                # Memory limit for worker container
CATOCODE_CPUS=4                                # CPU limit for worker container

# ── Embedding (optional, for issue deduplication) ─────────────────────────
# Uses OpenAI-compatible API for vector embeddings + Claude Haiku for summarization
#EMBEDDING_API_KEY=sk-...                       # OpenAI-compatible API key
#EMBEDDING_BASE_URL=https://api.openai.com/v1   # Embedding API base URL
#EMBEDDING_MODEL=text-embedding-3-large         # Embedding model name
#SUMMARY_MODEL=claude-haiku-4-5-20251001        # Model for issue summarization
