# ─────────────────────────────────────────────────────────────────────────────
# CatoCode Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://...    # Custom API endpoint (e.g. proxy). Omit to use Anthropic directly.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — fine for single-user / small teams)
# Data stored in ./data/catocode.db relative to working directory
#
# PostgreSQL (recommended for multi-user production)
# DATABASE_URL=postgresql://catocode:password@localhost:5432/catocode

# ── GitHub App (SaaS mode — required for multi-user) ─────────────────────────
# Create at: https://github.com/settings/apps/new
# Required permissions: Issues (R/W), Pull Requests (R/W), Contents (R/W)
# Required webhook events: Issues, Pull requests, Issue comments, Pull request reviews
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_WEBHOOK_SECRET=your-random-webhook-secret   # openssl rand -hex 32
GITHUB_APP_NAME=catocode-bot                           # slug from your App's URL

# ── GitHub OAuth (SaaS mode — for user login) ─────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: https://your-domain.com/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=Ov23li...
GITHUB_OAUTH_CLIENT_SECRET=your-oauth-secret

# ── Session / Encryption ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET_KEY=your-64-char-hex-string

# ── URLs ──────────────────────────────────────────────────────────────────────
CATOCODE_BASE_URL=https://api.your-domain.com          # Backend URL (no trailing slash)
FRONTEND_URL=https://your-domain.com                   # Frontend URL for CORS

# ── CLI mode only (single-user, Personal Access Token) ───────────────────────
# Use this instead of GitHub App when you only need one user
# GITHUB_TOKEN=ghp_...
# GITHUB_APP_INSTALLATION_ID=789   # Only needed for single-installation App auth

# ── Embedding / RAG dedup (optional) ─────────────────────────────────────────
# Powers patrol issue deduplication. If unset, dedup is disabled gracefully.
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://yunwu.ai/v1
# EMBEDDING_MODEL=text-embedding-3-large

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_CONCURRENT=3
CATOCODE_PATROL_MAX_ISSUES=5
CATOCODE_PATROL_WINDOW_HOURS=12
CATOCODE_MEM=8g
CATOCODE_CPUS=4

# ── Git identity (for commits made inside the worker container) ───────────────
GIT_USER_NAME=CatoCode
GIT_USER_EMAIL=catocode@bot.local
