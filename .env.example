# ── Database ─────────────────────────────────────────────────────────────
# Option A (default): SQLite — no configuration needed
# Data is stored in ~/.catocode/catocode.db (or CATOCODE_DB_PATH)

# Option B: PostgreSQL (for multi-user / production deployments)
# CATOCODE_DATABASE_URL=postgresql://catocode:password@localhost:5432/catocode


ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub Auth: choose ONE option ──────────────────────────────────────

# Option A: Personal Access Token (simplest, good for 1-2 repos)
GITHUB_TOKEN=ghp_...

# Option B: GitHub App (recommended for production / multiple users)
# Create a GitHub App at https://github.com/settings/apps/new
# Required permissions: Issues (R/W), Pull Requests (R/W), Contents (R/W)
# Required events: Issues, Pull requests, Issue comments, Pull request reviews
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# GITHUB_APP_INSTALLATION_ID=789
# GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret

# ── Webhook ─────────────────────────────────────────────────────────────
# Port to expose the webhook server on
WEBHOOK_PORT=8080

# For GitHub App mode, set the webhook URL to:
#   https://your-domain.com/webhook/app
# For personal token mode, set it to:
#   https://your-domain.com/webhook/github/{owner-repo}

# ── Optional tuning ─────────────────────────────────────────────────────
MAX_CONCURRENT=3
CATOCODE_PATROL_MAX_ISSUES=5
CATOCODE_PATROL_WINDOW_HOURS=12

# Git identity for commits made by CatoCode
GIT_USER_NAME=CatoCode
GIT_USER_EMAIL=catocode@bot.local
